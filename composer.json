{
  "name": "pteal79/mobile-file-cache",
  "description": "Offline-friendly remote file caching for NativePHP and Laravel.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "illuminate/contracts": "^12.0",
    "illuminate/database": "^12.0",
    "illuminate/filesystem": "^12.0",
    "illuminate/http": "^12.0",
    "illuminate/queue": "^12.0",
    "illuminate/support": "^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "PTeal79\\MobileFileCache\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PTeal79\\MobileFileCache\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "PTeal79\\MobileFileCache\\MobileFileCacheServiceProvider"
      ],
      "aliases": {
        "MobileFileCache": "PTeal79\\MobileFileCache\\Facades\\MobileFileCache"
      }
    }
  },
  "scripts": {
    "test": "vendor/bin/pest"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
