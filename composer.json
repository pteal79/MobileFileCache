{
    "name": "pteal79/mobile-file-cache",
    "description": "Cache remote images and PDF files locally for offline access in NativePHP apps",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "PTeal79"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "PTeal79\\MobileFileCache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PTeal79\\MobileFileCache\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PTeal79\\MobileFileCache\\MobileFileCacheServiceProvider"
            ],
            "aliases": {
                "MobileFileCache": "PTeal79\\MobileFileCache\\Facades\\MobileFileCache"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
